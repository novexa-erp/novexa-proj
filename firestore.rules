rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isValidEmail(email) {
      return email.matches('.*@.*[.].*');
    }

    match /users/{userId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId)
        && request.resource.data.email is string
        && isValidEmail(request.resource.data.email)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100;
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);

      match /invoices/{invoiceId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      match /customers/{customerId} {
        allow read, write: if isSignedIn() && isOwner(userId);

        // Customer ki apni invoices subcollection
        match /invoices/{invoiceId} {
          allow read, write: if isSignedIn() && isOwner(userId);
        }
      }

      match /products/{productId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      match /payments/{paymentId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      match /purchases/{purchaseId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      match /suppliers/{supplierId} {
        allow read, write: if isSignedIn() && isOwner(userId);

        // Supplier ki apni purchases subcollection
        match /purchases/{purchaseId} {
          allow read, write: if isSignedIn() && isOwner(userId);
        }
      }

      match /expenses/{expenseId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      match /quotations/{quotationId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      match /hr/{hrId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      match /reports/{reportId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      match /settings/{settingId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
    }

    match /businesses/{businessId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.businessName is string
        && request.resource.data.businessName.size() > 0;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
