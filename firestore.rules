rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: check if requester is the Super Admin ─────────────────────────
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == "LpfAmmxDFtZgLZnU2npnFknF8tu2";
    }

    // ── Users collection ─────────────────────────────────────────────────────
    // Each user can read/write only their own subcollections.
    // Admin (server-side via Admin SDK) bypasses these rules entirely.
    match /users/{uid} {
      // Users can read their own profile doc (for settings, name etc.)
      allow read: if request.auth != null && request.auth.uid == uid;
      // Only server (Admin SDK) can write user profile docs — deny client writes
      allow write: if false;

      // User's own subcollections — full read/write for owner only
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
        // Nested subcollections (e.g. suppliers/{id}/orders)
        match /{nested}/{nestedId} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
          match /{deep}/{deepId} {
            allow read, write: if request.auth != null && request.auth.uid == uid;
          }
        }
      }
    }

    // ── Admin Config (Package Manager, Plan Settings) ─────────────────────────
    // Super Admin can read & write. All logged-in users can read (to load plan limits/tabs).
    match /adminConfig/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
      match /{subcol}/{subId} {
        allow read:  if request.auth != null;
        allow write: if isAdmin();
      }
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
